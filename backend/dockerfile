FROM node:18-alpine

# Install build dependencies and compilers
RUN apk update && apk add --no-cache \
    gcc \
    g++ \
    make \
    python3 \
    # Build tools and utilities
    build-base \
    # Additional optimization
    binutils-gold

# We won't install Java in the container since it's too heavy
# Instead, the application will detect and handle Java absence gracefully

# Set working directory
WORKDIR /usr/src/backend

# Copy package files and install dependencies
COPY package*.json ./
RUN npm ci --only=production

# Copy application code
COPY . .

# Set environment variables
ENV NODE_ENV=production
ENV PORT=5001
# Mark as Render environment for application's runtime detection
ENV RENDER=true

# Expose the application port
EXPOSE 5001

# Health check
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD node -e "const http = require('http'); const options = { timeout: 2000, host: 'localhost', port: 5001, path: '/api/health' }; const req = http.request(options, (res) => { process.exit(res.statusCode === 200 ? 0 : 1); }); req.on('error', () => process.exit(1)); req.end();"

# Start the application
CMD ["npm", "start"]
