# ==========================================
# PURPLE COMPILER & TYPESPEED - CONSOLIDATED ENV
# ==========================================

# 🔹 BACKEND CONFIGURATION
PORT=5001
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.<id>.mongodb.net/?retryWrites=true&w=majority

# 🔹 EXTERNAL APIs & SERVICES
# Get your token from: https://api.onlinecompiler.io
COMPILER_API_KEY=your_onlinecompiler_token

# (Optional) For AI code suggestions
GEMINI_API_KEY=your_gemini_api_key

# 🔹 AUTHENTICATION (JWT)
JWT_SECRET=your_secure_random_string
JWT_EXPIRES_IN=1d

# 🔹 FRONTEND CONFIGURATION (Vite)
# For Local Development:
VITE_BASE_URL=http://localhost:5001/
VITE_SOCKET_URL=http://localhost:5001

# For Production (Example):
# VITE_BASE_URL=https://your-backend-url.vercel.app/
# VITE_SOCKET_URL=https://your-backend-url.vercel.app
